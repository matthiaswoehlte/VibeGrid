{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["local-rules"],
  "rules": {
    "@next/next/no-html-link-for-pages": "off"
  },
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "excludedFiles": ["tests/**"],
      "rules": {
        "local-rules/no-direct-set-state": "error"
      }
    },
    {
      "files": ["lib/store/**/*.ts"],
      "excludedFiles": [
        "lib/store/recording-set.ts",
        "lib/store/history-actions.ts"
      ],
      "rules": {
        "local-rules/no-bare-set-in-store": "error"
      }
    }
  ]
}
