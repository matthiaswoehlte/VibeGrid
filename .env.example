# Cloudflare R2 (S3-compatible) — copy to `.env.local` and fill in actual
# values. Next.js dotenv does NOT expand ${VAR} references, so the endpoint
# URL must contain the literal account-id hex, not a placeholder.

# 32-char hex from Cloudflare Dashboard → R2 → "Account ID" (top-right).
R2_ACCOUNT_ID=

# R2 API token (S3-compatible), with R/W on the bucket below.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name (created in Cloudflare R2 dashboard).
R2_BUCKET=vibegrid

# Endpoint — MUST be `https://<your R2_ACCOUNT_ID hex>.eu.r2.cloudflarestorage.com`
# (substitute the hex literally; dotenv does not expand variables).
R2_ENDPOINT=https://YOUR_R2_ACCOUNT_ID_HERE.eu.r2.cloudflarestorage.com

# Custom HTTPS domain bound to the bucket (R2 itself does NOT serve over
# public HTTPS without one — see KNOWN_LIMITATIONS.md).
R2_PUBLIC_URL=https://media.vibegrid.example.com

# Anthropic (Auto-Preset) — leave empty to disable the ✨ button.
ANTHROPIC_API_KEY=

# D1 (v0.2):
D1_DATABASE_ID=
