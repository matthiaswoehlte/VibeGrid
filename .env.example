# Cloudflare R2 (S3-compatible) — copy to `.env.local` and fill in actual
# values. Next.js dotenv does NOT expand ${VAR} references, so the endpoint
# URL must contain the literal account-id hex, not a placeholder.

# 32-char hex from Cloudflare Dashboard → R2 → "Account ID" (top-right).
R2_ACCOUNT_ID=

# R2 API token (S3-compatible), with R/W on the bucket below.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name (created in Cloudflare R2 dashboard).
R2_BUCKET=vibegrid

# Endpoint — TWO valid forms depending on the bucket's jurisdiction:
#   Auto (default):  https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
#   EU jurisdiction: https://${R2_ACCOUNT_ID}.eu.r2.cloudflarestorage.com
# The `${R2_ACCOUNT_ID}` reference IS expanded by Next.js dotenv-expand at
# runtime. Mismatching the jurisdiction here returns SignatureDoesNotMatch.
R2_ENDPOINT=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# Custom HTTPS domain bound to the bucket (R2 itself does NOT serve over
# public HTTPS without one — see KNOWN_LIMITATIONS.md).
R2_PUBLIC_URL=https://media.vibegrid.example.com

# Anthropic (Auto-Preset) — leave empty to disable the ✨ button.
ANTHROPIC_API_KEY=

# ElevenLabs TTS (Voice picker in CharacterForm). Optional — when empty,
# the ElevenLabs voice list returns 503 and the picker shows a hint to
# add the key. Edge TTS works without any key.
ELEVENLABS_API_KEY=

# D1 (v0.2):
D1_DATABASE_ID=

# --- Plan 7: Better-Auth + Supabase Postgres (project save/load) ---

# Postgres connection string for direct pg access (used by Next.js API
# routes and Better-Auth). For Supabase: use the pooler URL with
# `pgbouncer=true` for the runtime, and the direct URL for migrations.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Supabase (only required for tests / verification — VG_projects access
# itself runs through DATABASE_URL, not PostgREST).
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Better-Auth: secret used to sign session cookies. Generate via
# `openssl rand -hex 32` (or any 64-char hex string).
BETTER_AUTH_SECRET=

# Base URL of the running VibeGrid app — used by Better-Auth for
# trustedOrigins and by the React client for the auth API base path.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Plan 8 / SceneFlow: fal.ai ---
# Generate at https://fal.ai/dashboard/keys. Server-only — never exposed
# to the client. `lib/fal/client.ts` throws at import if unset.
FAL_KEY=
